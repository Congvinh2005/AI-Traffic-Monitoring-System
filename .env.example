# ========================================
# CẤU HÌNH DATABASE - AI TRAFFIC MONITORING
# ========================================
# Copy file này thành .env và cập nhật thông tin database của bạn
# Cách sử dụng:
# 1. Copy: cp .env.example .env
# 2. Chỉnh sửa thông tin trong .env
# 3. Flask app sẽ tự động đọc từ file .env

# ========================================
# MYSQL DATABASE CONFIGURATION
# ========================================

# Host của MySQL (thường là localhost hoặc 127.0.0.1)
MYSQL_HOST=localhost

# Port của MySQL (mặc định là 3306)
MYSQL_PORT=3306

# Username của MySQL (thường là root)
MYSQL_USER=root

# Password của MySQL (để trống nếu không có)
MYSQL_PASSWORD=

# Tên database (phải tạo trước bằng cách import database_schema.sql)
MYSQL_DB=

# ========================================
# FLASK APPLICATION CONFIGURATION
# ========================================

# Secret key cho session (nên thay đổi trong production)
# Tạo key mới: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode (True cho development, False cho production)
FLASK_DEBUG=True

# Port chạy Flask app
FLASK_PORT=5000

# Host (0.0.0.0 để truy cập từ mạng nội bộ)
FLASK_HOST=0.0.0.0

# ========================================
# SESSION CONFIGURATION
# ========================================

# Thời gian session (tính bằng giờ)
SESSION_TIMEOUT=24

# ========================================
# OTHER CONFIGURATION
# ========================================

# CORS allowed origins (dùng cho API)
CORS_ORIGINS=*
ai_traffic_monitoring